# ===========================
# ATTENDX Backend Environment
# ===========================
# Copy this file to .env and fill in your values

# Flask
FLASK_APP=run.py
FLASK_ENV=production
FLASK_DEBUG=0
SECRET_KEY=your-secret-key-here

# Database (MySQL)
DB_HOST=your-db-host.com
DB_PORT=3306
DB_USER=your-db-user
DB_PASSWORD=your-db-password
DB_NAME=attendance_db

# JWT
JWT_SECRET_KEY=your-jwt-secret-here
JWT_ACCESS_TOKEN_EXPIRES=86400
JWT_REFRESH_TOKEN_EXPIRES=604800

# Mail (Gmail SMTP)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_DEFAULT_SENDER=your-email@gmail.com

# Face Recognition
FACE_RECOGNITION_TOLERANCE=0.55
FACE_MIN_MATCH_VOTES=2
FACE_CAPTURE_COUNT=40
FACE_MIN_IMAGES=20
FACE_RECOMMENDED_IMAGES=30

# Default Passwords
DEFAULT_STUDENT_PASSWORD=Institution@123
DEFAULT_TEACHER_PASSWORD=Faculty@123

# Super Admin IP Whitelist (empty = allow all)
SUPER_ADMIN_WHITELISTED_IPS=

# Attendance
ATTENDANCE_MIN_PERCENTAGE=75.0

# Server
HOST=0.0.0.0
PORT=5001
